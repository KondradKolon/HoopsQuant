# Database - Use Supabase PostgreSQL connection string for production
DATABASE_URL=postgresql://postgres.xxxxx:password@db.xxxxx.supabase.co:5432/postgres

# Supabase (optional - for future auth integration)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# APIs
ODDS_API_KEY=your_odds_api_key

# Bookmakers (comma-separated; odds-api.io allows 2 active per account)
# Verify exact names: GET https://api.odds-api.io/v3/bookmakers/selected?apiKey=YOUR_KEY
BOOKMAKERS=Superbet,Stake

# Comma-separated allowed CORS origins (frontend URLs)
ALLOWED_ORIGINS=http://localhost:3000,https://hoops-quant.vercel.app

# Environment
ENV=development

